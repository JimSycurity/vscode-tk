{
  "name": "vscode-tk",
  "displayName": "vscode-tk",
  "description": "VS Code extension for wedow/ticket Markdown tickets.",
  "version": "0.0.2",
  "publisher": "jimsycurity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/JimSycurity/vscode-tk.git"
  },
  "bugs": {
    "url": "https://github.com/JimSycurity/vscode-tk/issues"
  },
  "homepage": "https://github.com/JimSycurity/vscode-tk#readme",
  "keywords": [
    "tickets",
    "tk",
    "wedow-ticket",
    "issue-tracking"
  ],
  "files": [
    "out/extension.js",
    "out/tickets/*.js",
    "resources/**",
    "README.md",
    "CHANGELOG.md",
    "docs/release-assets.md",
    "LICENSE*",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:vscodeTk.tickets",
    "onCommand:vscode-tk.refresh",
    "onCommand:vscode-tk.switchProject",
    "onCommand:vscode-tk.selectProject",
    "onCommand:vscode-tk.search",
    "onCommand:vscode-tk.clearFilters",
    "onCommand:vscode-tk.openTicket",
    "onCommand:vscode-tk.openTicketPinned",
    "onCommand:vscode-tk.openTicketToSide",
    "onCommand:vscode-tk.copyTicketId",
    "onCommand:vscode-tk.revealTicketFile",
    "onCommand:vscode-tk.createTicket",
    "onCommand:vscode-tk.createChildTicket",
    "onCommand:vscode-tk.startTicket",
    "onCommand:vscode-tk.closeTicket",
    "onCommand:vscode-tk.reopenTicket",
    "onCommand:vscode-tk.addDependency",
    "onCommand:vscode-tk.removeDependency",
    "onCommand:vscode-tk.linkTicket",
    "onCommand:vscode-tk.unlinkTicket",
    "onCommand:vscode-tk.addNote"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodeTk",
          "title": "Tickets",
          "icon": "resources/ticket.svg"
        }
      ]
    },
    "views": {
      "vscodeTk": [
        {
          "id": "vscodeTk.tickets",
          "name": "Tickets"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-tk.refresh",
        "title": "Refresh Tickets",
        "category": "Tickets",
        "icon": "$(refresh)"
      },
      {
        "command": "vscode-tk.switchProject",
        "title": "Switch Ticket Project",
        "category": "Tickets",
        "icon": "$(repo)"
      },
      {
        "command": "vscode-tk.selectProject",
        "title": "Select Ticket Project",
        "category": "Tickets",
        "icon": "$(repo)"
      },
      {
        "command": "vscode-tk.search",
        "title": "Search Tickets",
        "category": "Tickets",
        "icon": "$(search)"
      },
      {
        "command": "vscode-tk.clearFilters",
        "title": "Clear Ticket Filters",
        "category": "Tickets",
        "icon": "$(clear-all)"
      },
      {
        "command": "vscode-tk.openTicket",
        "title": "Open Ticket",
        "category": "Tickets"
      },
      {
        "command": "vscode-tk.openTicketPinned",
        "title": "Open Ticket Pinned",
        "category": "Tickets"
      },
      {
        "command": "vscode-tk.openTicketToSide",
        "title": "Open Ticket to Side",
        "category": "Tickets"
      },
      {
        "command": "vscode-tk.copyTicketId",
        "title": "Copy Ticket ID",
        "category": "Tickets",
        "icon": "$(copy)"
      },
      {
        "command": "vscode-tk.revealTicketFile",
        "title": "Reveal Ticket File",
        "category": "Tickets"
      },
      {
        "command": "vscode-tk.createTicket",
        "title": "Create Ticket",
        "category": "Tickets",
        "icon": "$(add)"
      },
      {
        "command": "vscode-tk.createChildTicket",
        "title": "Add Child Ticket",
        "category": "Tickets",
        "icon": "$(new-folder)"
      },
      {
        "command": "vscode-tk.startTicket",
        "title": "Start Ticket",
        "category": "Tickets",
        "icon": "$(play)"
      },
      {
        "command": "vscode-tk.closeTicket",
        "title": "Close Ticket",
        "category": "Tickets",
        "icon": "$(check)"
      },
      {
        "command": "vscode-tk.reopenTicket",
        "title": "Reopen Ticket",
        "category": "Tickets",
        "icon": "$(debug-restart)"
      },
      {
        "command": "vscode-tk.addDependency",
        "title": "Add Dependency",
        "category": "Tickets",
        "icon": "$(references)"
      },
      {
        "command": "vscode-tk.removeDependency",
        "title": "Remove Dependency",
        "category": "Tickets",
        "icon": "$(remove)"
      },
      {
        "command": "vscode-tk.linkTicket",
        "title": "Link Ticket",
        "category": "Tickets",
        "icon": "$(link)"
      },
      {
        "command": "vscode-tk.unlinkTicket",
        "title": "Unlink Ticket",
        "category": "Tickets",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "vscode-tk.addNote",
        "title": "Add Note",
        "category": "Tickets",
        "icon": "$(note)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscode-tk.createTicket",
          "when": "view == vscodeTk.tickets",
          "group": "navigation@0"
        },
        {
          "command": "vscode-tk.refresh",
          "when": "view == vscodeTk.tickets",
          "group": "navigation@1"
        },
        {
          "command": "vscode-tk.switchProject",
          "when": "view == vscodeTk.tickets",
          "group": "navigation@2"
        },
        {
          "command": "vscode-tk.search",
          "when": "view == vscodeTk.tickets",
          "group": "navigation@3"
        },
        {
          "command": "vscode-tk.clearFilters",
          "when": "view == vscodeTk.tickets",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-tk.openTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "navigation@1"
        },
        {
          "command": "vscode-tk.openTicketPinned",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "navigation@2"
        },
        {
          "command": "vscode-tk.openTicketToSide",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "navigation@3"
        },
        {
          "command": "vscode-tk.copyTicketId",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "navigation@4"
        },
        {
          "command": "vscode-tk.createChildTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "mutation@0"
        },
        {
          "command": "vscode-tk.startTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "mutation@1"
        },
        {
          "command": "vscode-tk.closeTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "mutation@2"
        },
        {
          "command": "vscode-tk.reopenTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "mutation@3"
        },
        {
          "command": "vscode-tk.addDependency",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "relationships@1"
        },
        {
          "command": "vscode-tk.removeDependency",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "relationships@2"
        },
        {
          "command": "vscode-tk.linkTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "relationships@3"
        },
        {
          "command": "vscode-tk.unlinkTicket",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "relationships@4"
        },
        {
          "command": "vscode-tk.addNote",
          "when": "view == vscodeTk.tickets && viewItem == ticket",
          "group": "mutation@4"
        },
        {
          "command": "vscode-tk.selectProject",
          "when": "view == vscodeTk.tickets && viewItem == project",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "vscode-tk",
      "properties": {
        "vscode-tk.projectRoot": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Optional path to a wedow/ticket project root or .tickets directory. When unset, vscode-tk discovers the active project from the workspace."
        },
        "vscode-tk.allowExternalProjectRoot": {
          "type": "boolean",
          "default": false,
          "description": "Allow vscode-tk.projectRoot to point outside the opened workspace. Keep disabled unless you intentionally want vscode-tk to read, watch, open, and future mutation commands to target that external ticket project."
        },
        "vscode-tk.command": {
          "type": "string",
          "default": "tk",
          "scope": "machine",
          "description": "Ticket CLI executable name or absolute path used for mutation commands. Use 'gtk' for go-ticket side-by-side installs. Arguments are not supported; commands are executed without a shell."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run compile && node --test out/test/*.test.js",
    "package:dry-run": "vsce ls",
    "package:vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  }
}
